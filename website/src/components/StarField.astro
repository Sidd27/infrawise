---
// Deterministic seeded random — same output every build
function sr(seed: number): number {
  const x = Math.sin(seed + 1) * 10000
  return x - Math.floor(x)
}

const PALETTE = ['#ffffff', '#ffffff', '#ffffff', '#93c5fd', '#c4b5fd', '#6ee7b7']

const stars = Array.from({ length: 220 }, (_, i) => ({
  cx:      Math.round(sr(i * 3 + 1) * 1440),
  cy:      Math.round(sr(i * 3 + 2) * 3000),
  r:       parseFloat((sr(i * 7 + 3) * 0.5 + 0.5).toFixed(1)),
  opacity: parseFloat((sr(i * 11 + 5) * 0.5 + 0.2).toFixed(2)),
  fill:    PALETTE[Math.floor(sr(i * 13 + 7) * PALETTE.length)],
}))
---

<style>
  .star-field {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    z-index: 0;
    pointer-events: none;
  }
</style>

<svg class="star-field" viewBox="0 0 1440 3000" preserveAspectRatio="xMidYMin slice"
     xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
  <defs>
    <radialGradient id="nb1" cx="60%" cy="10%" r="35%">
      <stop offset="0%"   stop-color="#4f46e5" stop-opacity="0.22"/>
      <stop offset="100%" stop-color="#4f46e5" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="nb2" cx="50%" cy="38%" r="30%">
      <stop offset="0%"   stop-color="#0d9488" stop-opacity="0.16"/>
      <stop offset="100%" stop-color="#0d9488" stop-opacity="0"/>
    </radialGradient>
    <radialGradient id="nb3" cx="42%" cy="68%" r="28%">
      <stop offset="0%"   stop-color="#7c3aed" stop-opacity="0.14"/>
      <stop offset="100%" stop-color="#7c3aed" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1440" height="3000" fill="url(#nb1)"/>
  <rect width="1440" height="3000" fill="url(#nb2)"/>
  <rect width="1440" height="3000" fill="url(#nb3)"/>
  {stars.map(s => (
    <circle cx={s.cx} cy={s.cy} r={s.r} fill={s.fill} opacity={s.opacity}/>
  ))}
</svg>
