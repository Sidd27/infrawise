---
const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<style>
  .hero {
    position: relative;
    z-index: 2;
    padding: 100px 24px 96px;
  }
  .hero-inner {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 60px);
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 12px;
    border: 1px solid rgba(52, 211, 153, 0.3);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 600;
    color: var(--teal);
    margin-bottom: 24px;
  }
  .hero-headline {
    font-size: clamp(36px, 5vw, 54px);
    font-weight: 900;
    line-height: 1.1;
    color: var(--text-primary);
    letter-spacing: -1.5px;
    margin-bottom: 20px;
  }
  .hero-subtext {
    font-size: 17px;
    color: var(--text-secondary);
    line-height: 1.65;
    margin-bottom: 36px;
    max-width: 560px;
  }
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 13px 22px;
    background: #0b1220;
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
    color: var(--teal);
    cursor: pointer;
    border: none;
    letter-spacing: 0.01em;
    transition: background 0.15s;
    position: relative;
  }
  .hero-install:hover { background: #0f1a2e; }
  .hero-install-copy {
    opacity: 0.45;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .hero-install:hover .hero-install-copy { opacity: 0.75; }
  .hero-install-copied {
    font-size: 11px;
    font-family: var(--font-sans);
    color: var(--teal);
    white-space: nowrap;
  }
</style>

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
      </svg>
      Open Source · MIT
    </div>

    <p class="label">MCP Infrastructure Layer</p>

    <h1 class="hero-headline">
      Your AI coding assistant<br />
      finally knows your infra.
    </h1>

    <p class="hero-subtext">
      Infrawise gives Claude Code, Cursor, and Windsurf a real-time, deterministic map of your
      AWS services, databases, and IaC — so they stop writing code that assumes wrong indexes,
      missing queues, and stale schemas.
    </p>

    <div class="hero-actions">
      <a href={`${base}/getting-started/installation/`} class="btn btn--primary">Get Started</a>
      <button class="hero-install" id="hero-install-btn" title="Copy install command">
        npm install -g infrawise
        <svg class="hero-install-copy" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
        </svg>
        <span class="hero-install-copied" id="hero-install-copied" aria-live="polite"></span>
      </button>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('hero-install-btn')
  const copied = document.getElementById('hero-install-copied')
  btn?.addEventListener('click', () => {
    navigator.clipboard.writeText('npm install -g infrawise')
    if (copied) {
      copied.textContent = 'copied!'
      setTimeout(() => { copied.textContent = '' }, 1800)
    }
  })
</script>
