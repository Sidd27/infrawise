const posts = [
  {
    title: 'Fix N+1 Trigger Patterns Where Lambda Functions Hammer the Same DynamoDB Partition Key',
    url: 'https://dev.to/siddharth_pandey_27/fix-n1-trigger-patterns-where-lambda-functions-hammer-the-same-dynamodb-partition-key-1m60',
    date: 'Jun 20, 2026',
    description: 'You add a sixth Lambda trigger to your OrderEvents table, deploy it, and within 20 minutes your SLA breaches. Here\'s how to detect and fix N+1 trigger patterns before they hit production.',
    tags: ['typescript', 'aws', 'dynamodb'],
    readingTime: 5,
    source: 'devto',
  },
  {
    title: 'Give Your AI Assistant Infrastructure Eyes Before It Writes Another Query',
    url: 'https://dev.to/siddharth_pandey_27/give-your-ai-assistant-infrastructure-eyes-before-it-writes-another-query-p0o',
    date: 'Jun 9, 2026',
    description: 'You asked Claude Code to add pagination to your order history endpoint. It generated a clean function — for a GSI that doesn\'t exist. Here\'s how to fix that.',
    tags: ['typescript', 'aws', 'dynamodb'],
    readingTime: 4,
    source: 'devto',
  },
  {
    title: 'How I gave Claude Code eyes on my infrastructure — and stopped flying blind',
    url: 'https://medium.com/@siddharthpandey_77104/how-i-gave-claude-code-eyes-on-my-infrastructure-and-stopped-flying-blind-4c200dfa8b8d',
    date: 'May 21, 2026',
    description: 'As a full-stack developer, I write the code. But I don\'t always know what happens after it deploys. Is my Lambda running out of memory? Is that SQS queue dropping messages silently?',
    tags: ['devops', 'claude-code', 'aws'],
    source: 'medium',
  },
  {
    title: 'AI Generated a DynamoDB Query That Could Never Work',
    url: 'https://dev.to/siddharth_pandey_27/ai-generated-a-dynamodb-query-that-could-never-work-53h9',
    date: 'May 13, 2026',
    description: 'I asked an AI coding assistant to generate a DynamoDB query. A few seconds later it confidently gave me code querying a GSI that didn\'t exist. Here\'s what went wrong and how to prevent it.',
    tags: ['ai', 'devops', 'architecture'],
    readingTime: 3,
    source: 'devto',
  },
] as const;
