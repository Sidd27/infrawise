<style>
  .trust-strip {
    position: relative;
    z-index: 2;
    padding: 0 24px 64px;
  }
  .trust-strip-inner {
    max-width: var(--max-page);
    margin: 0 auto;
    padding: 0 clamp(24px, 5vw, 60px);
  }
  .trust-items {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border: 1px solid var(--border-subtle);
    font-size: 13px;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--surface);
  }
  .trust-item:first-child { border-radius: var(--radius-sm) 0 0 var(--radius-sm); }
  .trust-item:last-child  { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; border-left: none; }
  .trust-item:not(:first-child):not(:last-child) { border-left: none; }
  .trust-icon { width: 14px; height: 14px; opacity: 0.7; flex-shrink: 0; }
  .trust-value { color: var(--text-primary); }
  .trust-growing {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--teal);
    background: rgba(52, 211, 153, 0.08);
    border: 1px solid rgba(52, 211, 153, 0.2);
    border-radius: 100px;
    padding: 2px 7px;
    margin-left: 4px;
  }
  .trust-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--teal);
    animation: pulse-dot 1.8s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }
  @media (max-width: 600px) {
    .trust-item { font-size: 12px; padding: 8px 14px; }
  }
</style>

<div class="trust-strip">
  <div class="trust-strip-inner">
    <div class="trust-items">

      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331zm4 0v1.336H8.001V8.667h5.334v5.331h-2.669zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002z"/>
        </svg>
        <span id="trust-downloads" class="trust-value">—</span>
        <span class="trust-growing">
          <span class="trust-dot"></span>
          growing
        </span>
      </div>

      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        <span id="trust-stars" class="trust-value">—</span>
      </div>

      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        <span class="trust-value">MIT</span> License
      </div>

      <div class="trust-item">
        <svg class="trust-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
        </svg>
        No telemetry · runs local
      </div>

    </div>
  </div>
</div>

<script>
  function fmt(n: number) { return n >= 1000 ? `${(n / 1000).toFixed(1)}k` : String(n) }

  Promise.all([
    fetch('https://api.npmjs.org/downloads/point/last-month/infrawise').then(r => r.json()),
    fetch('https://api.github.com/repos/Sidd27/infrawise').then(r => r.json()),
  ]).then(([npm, gh]) => {
    const dl = document.getElementById('trust-downloads')
    const st = document.getElementById('trust-stars')
    if (dl) dl.textContent = `${fmt(npm.downloads)} downloads / mo`
    if (st) st.textContent = `★ ${gh.stargazers_count} stars`
  }).catch(() => {})
</script>
