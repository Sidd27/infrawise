---
import '../styles/global.css'
import Nav from '../components/Nav.astro'
import StarField from '../components/StarField.astro'
import InfraNodes from '../components/InfraNodes.astro'
import Hero from '../components/Hero.astro'
import TrustStrip from '../components/TrustStrip.astro'
import ProblemSection from '../components/ProblemSection.astro'
import QuickStart from '../components/QuickStart.astro'
import HowItWorks from '../components/HowItWorks.astro'
import EditorsSection from '../components/EditorsSection.astro'
import ArchDiagram from '../components/ArchDiagram.astro'
import UseCases from '../components/UseCases.astro'
import BlogSection from '../components/BlogSection.astro'
import DocsCta from '../components/DocsCta.astro'

const base = import.meta.env.BASE_URL.replace(/\/$/, '')
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Infrawise — AI-aware infrastructure layer</title>
  <meta name="description" content="Infrawise connects your AI coding assistant to your real infrastructure. 16 MCP tools. One command." />
  <link rel="canonical" href="https://sidd27.github.io/infrawise/" />
  <link rel="icon" type="image/png" href={`${base}/favicon.png`} />
  <meta property="og:type"        content="website" />
  <meta property="og:url"         content="https://sidd27.github.io/infrawise/" />
  <meta property="og:site_name"   content="Infrawise" />
  <meta property="og:title"       content="Infrawise — AI-aware infrastructure layer" />
  <meta property="og:description" content="Infrawise connects your AI coding assistant to your real infrastructure. 16 MCP tools. One command." />
  <meta property="og:image"       content="https://sidd27.github.io/infrawise/og-image.jpg" />
  <meta property="og:image:type"   content="image/jpeg" />
  <meta property="og:image:width"  content="1200" />
  <meta property="og:image:height" content="630" />
  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content="Infrawise — AI-aware infrastructure layer" />
  <meta name="twitter:description" content="Infrawise connects your AI coding assistant to your real infrastructure. 16 MCP tools. One command." />
  <meta name="twitter:image"       content="https://sidd27.github.io/infrawise/og-image.jpg" />
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Infrawise",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "macOS, Linux, Windows",
    "url": "https://sidd27.github.io/infrawise/",
    "downloadUrl": "https://www.npmjs.com/package/infrawise",
    "softwareVersion": "0.13.1",
    "releaseNotes": "https://github.com/Sidd27/infrawise/releases",
    "description": "Infrawise is an open-source MCP server that gives AI coding assistants like Claude Code and Cursor a real-time, read-only map of your AWS infrastructure. It runs 29 rule-based analyzers, exposes 16 MCP tools, and never stores or transmits your infrastructure data.",
    "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
    "license": "https://github.com/Sidd27/infrawise/blob/main/LICENSE",
    "codeRepository": "https://github.com/Sidd27/infrawise",
    "author": { "@type": "Person", "name": "Sidd27", "url": "https://github.com/Sidd27" },
    "keywords": ["MCP server", "infrastructure", "AWS", "Claude Code", "Cursor", "AI coding assistant", "Model Context Protocol"]
  })}</script>
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is Infrawise?",
        "acceptedAnswer": { "@type": "Answer", "text": "Infrawise is an open-source MCP (Model Context Protocol) server that gives AI coding assistants like Claude Code and Cursor a real-time, read-only map of your AWS infrastructure, databases, and IaC files. It runs 29 rule-based analyzers and exposes 16 MCP tools your AI can call while writing code — all locally, with no data leaving your machine." }
      },
      {
        "@type": "Question",
        "name": "What is an MCP server?",
        "acceptedAnswer": { "@type": "Answer", "text": "MCP (Model Context Protocol) is an open standard that lets AI coding assistants like Claude Code and Cursor call external tools during code generation. An MCP server exposes tools — functions the AI can invoke to fetch real data — so the assistant can ground its output in actual system state instead of guessing." }
      },
      {
        "@type": "Question",
        "name": "How do I install Infrawise?",
        "acceptedAnswer": { "@type": "Answer", "text": "Install Infrawise with npm: `npm install -g infrawise`. Then run `infrawise start --claude` to scan your infrastructure and connect Claude Code, or `infrawise start --cursor` for Cursor. Requires Node.js 20+ and AWS credentials already configured." }
      },
      {
        "@type": "Question",
        "name": "Does Infrawise work with Claude Code?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Running `infrawise start --claude` writes `.mcp.json` to your project directory. Claude Code reads this file automatically on next launch and registers all 16 Infrawise tools — no extension or plugin needed." }
      },
      {
        "@type": "Question",
        "name": "Does Infrawise store or transmit my infrastructure data?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Infrawise runs entirely on your local machine. It never sends infrastructure data, findings, or configuration to any external server. There is no telemetry and no cloud sync. Secret values and SSM parameter values are never read." }
      },
      {
        "@type": "Question",
        "name": "What AWS services does Infrawise analyze?",
        "acceptedAnswer": { "@type": "Answer", "text": "Infrawise analyzes DynamoDB, Lambda, SQS (including FIFO queues and visibility timeout checks), SNS, Secrets Manager, SSM Parameter Store, S3, CloudWatch Logs, EventBridge, API Gateway, and RDS. It also reads PostgreSQL, MySQL, and MongoDB databases, and IaC files from Terraform, CloudFormation, and CDK." }
      },
      {
        "@type": "Question",
        "name": "Does Infrawise need write permissions to AWS?",
        "acceptedAnswer": { "@type": "Answer", "text": "No. Infrawise only calls read-only AWS APIs (Describe, List, Get). It never creates, modifies, or deletes any AWS resource. The minimum IAM policy uses only read actions." }
      },
      {
        "@type": "Question",
        "name": "Can I use Infrawise without a real AWS account?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. The LocalStack demo lets you run Infrawise against locally emulated AWS services using Docker. You need a free LocalStack account but no real AWS account or credentials." }
      }
    ]
  })}</script>
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Infrawise",
    "url": "https://sidd27.github.io/infrawise/",
    "description": "AI-aware infrastructure layer. MCP server that gives AI coding assistants real-time context about your AWS infrastructure.",
    "publisher": { "@type": "Person", "name": "Sidd27", "url": "https://github.com/Sidd27" }
  })}</script>
  <script type="application/ld+json">{JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to connect Infrawise to Claude Code",
    "description": "Set up the Infrawise MCP server so Claude Code has real-time context about your AWS infrastructure.",
    "totalTime": "PT2M",
    "supply": [{ "@type": "HowToSupply", "name": "Node.js 20+" }, { "@type": "HowToSupply", "name": "AWS credentials configured" }],
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Install Infrawise globally", "text": "Run: npm install -g infrawise" },
      { "@type": "HowToStep", "position": 2, "name": "Start and connect to Claude Code", "text": "Run: infrawise start --claude — this scans your infrastructure and writes .mcp.json to your project" },
      { "@type": "HowToStep", "position": 3, "name": "Open your project in Claude Code", "text": "Claude Code reads .mcp.json automatically and registers all 16 Infrawise MCP tools — no extension needed" }
    ]
  })}</script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Libre+Baskerville:wght@700&family=JetBrains+Mono:wght@400;500&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Libre+Baskerville:wght@700&family=JetBrains+Mono:wght@400;500&display=swap" /></noscript>
</head>
<body>
  <div class="page-shell">
    <StarField />
    <InfraNodes />
    <Nav />
    <main>
      <Hero />
      <TrustStrip />
      <ProblemSection />
      <UseCases />
      <QuickStart />
      <HowItWorks />
      <EditorsSection />
      <ArchDiagram />
      <BlogSection />
      <DocsCta />
    </main>
  </div>
</body>
</html>

<style is:global>
  /* Reset + base — landing page only, does not touch Starlight docs */
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html, body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body { overflow-x: hidden; }
  a    { color: inherit; text-decoration: none; }
  img, svg { display: block; }

  .page-shell {
    position: relative;
    min-height: 100vh;
  }

  .label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--indigo);
  }
  .label--teal { color: var(--teal); }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    transition: opacity 0.15s, transform 0.1s;
    text-decoration: none;
  }
  .btn:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn--primary {
    background: var(--gradient-cta);
    color: #fff;
    box-shadow: 0 4px 20px rgba(79, 70, 229, 0.35);
  }
  .btn--ghost {
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-subtle);
  }
</style>
