{
  "name": "infrawise",
  "version": "0.12.5",
  "mcpName": "io.github.Sidd27/infrawise",
  "description": "CLI-first infrastructure intelligence platform — analyzes DynamoDB, PostgreSQL, MySQL, MongoDB, SQS, SNS, SSM, Secrets Manager, Lambda, S3, API Gateway, CloudWatch Logs and exposes findings as an MCP server for Claude Code",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "infrastructure",
    "infrastructure-analysis",
    "aws",
    "dynamodb",
    "sqs",
    "sns",
    "lambda",
    "s3",
    "eventbridge",
    "cloudwatch",
    "secrets-manager",
    "ssm",
    "postgresql",
    "mysql",
    "mongodb",
    "serverless",
    "claude",
    "claude-code",
    "cursor",
    "ai-coding",
    "ai-tools",
    "devtools",
    "cli",
    "terraform",
    "cloudformation",
    "cdk",
    "api-gateway",
    "sqs-fifo"
  ],
  "agentskills": {
    "infrawise": "./AGENTS.md"
  },
  "homepage": "https://sidd27.github.io/infrawise/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sidd27/infrawise.git"
  },
  "license": "MIT",
  "type": "module",
  "bin": {
    "infrawise": "dist/cli/index.js"
  },
  "main": "dist/cli/index.js",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "tsc --noEmit false --outDir dist",
    "test": "vitest run --passWithNoTests",
    "coverage": "vitest run --coverage",
    "lint": "eslint src",
    "typecheck": "tsc",
    "format": "prettier --write src",
    "build-arch": "node scripts/build-arch.mjs",
    "generate-diagrams": "node scripts/build-arch.mjs",
    "record": "bash docs/demo/record.sh",
    "dev": "node dist/cli/index.js serve",
    "release": "node scripts/release.js",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm format && git add $(git diff --cached --name-only --diff-filter=ACMR) && pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1068.0",
    "@aws-sdk/client-apigatewayv2": "^3.1068.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1048.0",
    "@aws-sdk/client-dynamodb": "^3.1048.0",
    "@aws-sdk/client-eventbridge": "^3.1051.0",
    "@aws-sdk/client-lambda": "^3.1048.0",
    "@aws-sdk/client-rds": "^3.1048.0",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/client-secrets-manager": "^3.1048.0",
    "@aws-sdk/client-sns": "^3.1048.0",
    "@aws-sdk/client-sqs": "^3.1048.0",
    "@aws-sdk/client-ssm": "^3.1048.0",
    "@aws-sdk/credential-providers": "^3.1048.0",
    "@fastify/cors": "^11.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "fastify": "^5.8.5",
    "inquirer": "^14.0.2",
    "js-yaml": "^4.1.0",
    "mongodb": "^7.2.0",
    "mysql2": "^3.9.0",
    "ora": "^9.4.0",
    "pg": "^8.11.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "ts-morph": "^28.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
