{
  "name": "@infrawise/adapters-aws-services",
  "version": "0.1.0",
  "description": "AWS service adapter for Infrawise — SQS, SNS, SSM, Secrets Manager, Lambda",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
