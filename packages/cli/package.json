{
  "name": "infrawise",
  "version": "0.1.0",
  "description": "CLI-first infrastructure intelligence platform for DynamoDB and PostgreSQL",
  "bin": {
    "infrawise": "dist/index.js"
  },
  "main": "dist/index.js",
